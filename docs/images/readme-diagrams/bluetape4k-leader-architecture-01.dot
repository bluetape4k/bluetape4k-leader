digraph "bluetape4k-leader-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "caller" [label="Caller work"];
  "core" [label="SuspendLeaderElector"];
  "group" [label="SuspendLeaderGroupElector"];
  "options" [label="Election options"];
  "adapter" [label="Backend adapter"];
  "listeners" [label="Listeners and metrics"];
  "store" [label="Ownership store"];
  "result" [label="Election result"];
  "caller" -> "core" [label="call"];
  "core" -> "group" [label="call"];
  "core" -> "options" [label="dependency"];
  "options" -> "adapter" [label="dependency"];
  "core" -> "adapter" [label="call"];
  "group" -> "adapter" [label="call"];
  "adapter" -> "store" [label="contention"];
  "adapter" -> "result" [label="success"];
  "adapter" -> "listeners" [label="metric"];
  "listeners" -> "result" [label="release"];
}
