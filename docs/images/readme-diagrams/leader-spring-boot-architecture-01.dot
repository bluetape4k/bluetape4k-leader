digraph "leader-spring-boot-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "imports" [label="AutoConfiguration Imports"];
  "props" [label="LeaderProperties Binding"];
  "backendBeans" [label="Backend Client Beans"];
  "optionalBeans" [label="Optional Platform Beans"];
  "coreAuto" [label="Core Auto-Config"];
  "factoryAuto" [label="AOP Factory Auto-Config"];
  "micrometerAuto" [label="Micrometer Auto-Config"];
  "aopAuto" [label="AOP Runtime Auto-Config"];
  "observeAuto" [label="Observe Config"];
  "factories" [label="Selectable Factory Beans"];
  "aspect" [label="CTW Leader Aspects"];
  "metrics" [label="Metrics And Health Beans"];
  "endpoint" [label="Status Registry Endpoint"];
  "imports" -> "coreAuto" [label="dependency"];
  "props" -> "coreAuto" [label="dependency"];
  "backendBeans" -> "factoryAuto" [label="dependency"];
  "optionalBeans" -> "micrometerAuto" [label="dependency"];
  "coreAuto" -> "factoryAuto" [label="dependency"];
  "factoryAuto" -> "micrometerAuto" [label="dependency"];
  "micrometerAuto" -> "aopAuto" [label="dependency"];
  "aopAuto" -> "observeAuto" [label="dependency"];
  "factoryAuto" -> "factories" [label="success"];
  "aopAuto" -> "aspect" [label="success"];
  "factories" -> "aspect" [label="call"];
  "micrometerAuto" -> "metrics" [label="metric"];
  "observeAuto" -> "endpoint" [label="success"];
}
