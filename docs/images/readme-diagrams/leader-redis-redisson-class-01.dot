digraph "leader-redis-redisson-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runAsyncIfLeader(lockName)\\n+ state(lockName): LeaderState"];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\ncoroutine context handle"];
  "groupContract" [label="<<core group interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName): T?\\n+ activeCount / availableSlots"];
  "suspendGroupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ state(lockName): LeaderGroupState"];
  "redissonLeader" [label="<<blocking + async implementation>>\\nRedissonLeaderElector\\nRedissonClient.getLock(lockName)\\ntryLock(wait, explicit lease)\\nbuilt-in watchdog disabled\\nLeaderLeaseAutoExtender owns renewals"];
  "redissonSuspend" [label="<<coroutine implementation>>\\nRedissonSuspendLeaderElector\\nuses RLock async API\\nPID-seeded owner id\\nwithContext(handle element)\\nNonCancellable unlock"];
  "redissonGroup" [label="<<expirable permit group>>\\nRedissonLeaderGroupElector\\ngetPermitExpirableSemaphore\\ntrySetPermits(maxLeaders)\\npermitId becomes slotId\\ngroup watchdog disabled"];
  "redissonSuspendGroup" [label="<<coroutine permit group>>\\nRedissonSuspend Group\\nRedissonSuspendLeaderGroupElector\\ntrySetPermitsAsync\\ntryAcquireAsync permitId\\nNonCancellable release/extend"];
  "factories" [label="<<factory + extensions>>\\nFactory Entrypoints\\nRedissonLeaderElectorFactory\\nRedissonLeaderGroupElectorFactory\\nRedissonSuspendLeaderElectorFactory\\nRedissonClient runIfLeader* extensions"];
  "singleDelegates" [label="<<RLock renewal delegates>>\\nSingle Extend Delegates\\nRedissonLockExtendDelegate\\nRedissonSuspendLockExtendDelegate\\nRKeys.expire renews lock key\\nWrongThread on owner mismatch"];
  "permitDelegates" [label="<<semaphore renewal delegates>>\\nPermit Extend Delegates\\nRedissonSemaphoreExtendDelegate\\nRedissonSuspendSemaphoreExtendDelegate\\nupdateLeaseTime by permitId\\nactive flag tracks failed extend"];
  "rlock" [label="<<single Redis lock primitive>>\\nRedisson RLock Path\\nRLock.tryLock(wait, lease, id)\\nRLock.unlock / unlockAsync(id)\\nRKeys.expire for minLease/extend\\nbuilt-in watchdog never used"];
  "semaphore" [label="<<group permit primitive>>\\nRPermitExpirableSemaphore\\nkey: lg:{lockName}\\ntrySetPermits idempotent\\ntryAcquire returns permitId\\nupdateLeaseTime delegates minLease"];
  "ownerId" [label="<<RLock owner identity>>\\nCoroutine Owner ID\\ntimestamp | pid%(2^10) | seq\\ngenerated per runIfLeader call\\nprevents coroutine false reentry\\nzero Redis round-trip"];
  "runtime" [label="<<Redis-backed objects>>\\nRedisson Runtime Objects\\nsingle RLock key: lockName\\ngroup semaphore: lg:{lockName}\\naudit RMap: lg:{lockName}:audit\\npermit TTL gives crash recovery"];
  "audit" [label="<<traceability side channel>>\\nLeaderSlot Audit Map\\nRMap<String,String>\\nfastPut permitId -> leaderId\\nexpire lease + 5s padding\\nfastRemove on release"];
  "classifier" [label="<<watchdog error policy>>\\nRedissonBackendErrorClassifier\\nRedisTimeout -> transient\\nRedisConnection -> transient\\nother RedisException -> non-transient\\nother errors delegated"];
  "redissonLeader" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "redissonSuspend" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "redissonGroup" -> "groupContract" [label="inherit", color="#4F83BF"];
  "redissonSuspendGroup" -> "suspendGroupContract" [label="inherit", color="#4F83BF"];
  "factories" -> "redissonLeader" [label="dependency", color="#758297"];
  "factories" -> "redissonSuspend" [label="dependency", color="#758297"];
  "factories" -> "redissonGroup" [label="dependency", color="#758297"];
  "factories" -> "redissonSuspendGroup" [label="dependency", color="#758297"];
  "redissonLeader" -> "singleDelegates" [label="handle delegate", color="#B9851B"];
  "redissonSuspend" -> "singleDelegates" [label="suspend delegate", color="#B9851B"];
  "redissonGroup" -> "permitDelegates" [label="permit delegate", color="#755BC6"];
  "redissonSuspendGroup" -> "permitDelegates" [label="suspend permit", color="#755BC6"];
  "singleDelegates" -> "rlock" [label="RKeys.expire", color="#B9851B"];
  "redissonSuspend" -> "ownerId" [label="owner id", color="#758297"];
  "ownerId" -> "rlock" [label="RLock owner", color="#758297"];
  "permitDelegates" -> "semaphore" [label="slot", color="#755BC6"];
  "redissonGroup" -> "semaphore" [label="slot", color="#755BC6"];
  "redissonSuspendGroup" -> "semaphore" [label="slot", color="#755BC6"];
  "rlock" -> "runtime" [label="RLock key", color="#758297"];
  "semaphore" -> "runtime" [label="permit key", color="#758297"];
  "ownerId" -> "runtime" [label="owner id stored", color="#758297"];
  "semaphore" -> "audit" [label="audit RMap", color="#2E8F89"];
  "audit" -> "runtime" [label="uses", color="#758297"];
  "classifier" -> "singleDelegates" [label="event", color="#2E8F89"];
  "classifier" -> "permitDelegates" [label="event", color="#2E8F89"];
}
