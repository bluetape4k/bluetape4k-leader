digraph "leader-spring-boot-sequence-02" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "caller" [label="Caller"];
  "aspect" [label="LeaderElectionAspect"];
  "scope" [label="Leader scope"];
  "elector" [label="Backend elector"];
  "method" [label="Annotated method"];
  "assert" [label="LockAssert"];
  "caller" -> "aspect" [label="invoke @LeaderElection method", color="#4F83BF"];
  "aspect" -> "scope" [label="check active leader scope", color="#2E8F89"];
  "aspect" -> "elector" [label="runIfLeader via configured elector", color="#B9851B"];
  "elector" -> "aspect" [label="ownership acquired", color="#3E9868"];
  "aspect" -> "scope" [label="open Real leader scope", color="#3E9868"];
  "aspect" -> "method" [label="proceed with annotated body", color="#4F83BF"];
  "method" -> "assert" [label="assertLocked inside scope", color="#718A35"];
  "method" -> "aspect" [label="return method result", color="#3E9868"];
  "aspect" -> "scope" [label="close scope and release lock", color="#755BC6"];
  "scope" -> "aspect" [label="reuse existing Real scope", color="#3E9868"];
  "aspect" -> "method" [label="proceed without backend reacquire", color="#4F83BF"];
  "aspect" -> "caller" [label="return method result", color="#3E9868"];
}
