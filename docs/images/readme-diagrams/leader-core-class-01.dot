digraph "leader-core-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "singleState" [label="<<state query>>\\nLeaderElectionState\\n+ state(lockName): LeaderState\\nbest-effort snapshot only"];
  "groupState" [label="<<group state query>>\\nLeaderGroupElectionState\\n+ maxLeaders: Int\\n+ activeCount(lockName): Int\\n+ availableSlots(lockName): Int\\n+ state(lockName): LeaderGroupState"];
  "asyncElector" [label="<<async contract>>\\nAsyncLeaderElector\\n+ runAsyncIfLeader(lockName)\\n+ runAsyncIfLeader(slot)\\n+ runAsyncIfLeaderResult(slot)"];
  "virtualElector" [label="<<virtual-thread contract>>\\nVirtualThreadLeaderElector\\n+ runAsyncIfLeader(lockName)\\n+ runAsyncIfLeader(slot)\\n+ runAsyncIfLeaderResult(slot)"];
  "asyncGroup" [label="<<async group contract>>\\nAsyncLeaderGroupElector\\n+ runAsyncIfLeader(lockName)\\n+ runAsyncIfLeader(slot)\\n+ runAsyncIfLeaderResult(slot)"];
  "leaderElector" [label="<<blocking contract>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runIfLeaderResult(lockName)\\n+ runIfLeader(slot)"];
  "suspendElector" [label="<<coroutine contract>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\n+ state(lockName): LeaderState"];
  "groupElector" [label="<<blocking group contract>>\\nLeaderGroupElector\\n+ runIfLeader(lockName): T?\\n+ runIfLeaderResult(lockName)\\n+ runIfLeader(slot)"];
  "suspendGroup" [label="<<coroutine group contract>>\\nSuspend Group Elector\\nSuspendLeaderGroupElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\n+ activeCount / availableSlots"];
  "slot" [label="<<identity carrier>>\\nLeaderSlot\\n+ lockName: String\\n+ leaderId: String\\nslot overload stamps audit identity"];
  "result" [label="<<sealed result>>\\nLeaderRunResult\\nElected(value, leaderId)\\nSkipped\\nActionFailed(cause)"];
  "events" [label="<<listener support>>\\nLeaderElection Events\\nLeaderElectionEventPublisher.events\\nLeaderElectionListenerRegistry\\nLeaderElectionListenerSupport"];
  "localSingle" [label="<<implementations>>\\nLocal Single-JVM Family\\nLocalLeaderElector -> LeaderElector\\nLocalAsync -> AsyncLeaderElector\\nLocalVirtualThread -> VirtualThreadLeaderElector\\nLocalSuspend -> SuspendLeaderElector"];
  "localGroup" [label="<<implementations>>\\nLocal Group Family\\nLocalLeaderGroup -> LeaderGroupElector\\nLocalAsyncGroup -> AsyncLeaderGroupElector\\nLocalSuspendGroup -> SuspendLeaderGroupElector\\nStrategic local variants wrap policy"];
  "asyncElector" -> "singleState" [label="inherit", color="#4F83BF"];
  "leaderElector" -> "asyncElector" [label="inherit", color="#4F83BF"];
  "virtualElector" -> "singleState" [label="inherit", color="#4F83BF"];
  "suspendElector" -> "singleState" [label="inherit", color="#4F83BF"];
  "asyncGroup" -> "groupState" [label="inherit", color="#4F83BF"];
  "groupElector" -> "asyncGroup" [label="inherit", color="#4F83BF"];
  "suspendGroup" -> "groupState" [label="inherit", color="#4F83BF"];
  "leaderElector" -> "result" [label="result API", color="#3E9868"];
  "groupElector" -> "result" [label="slot result", color="#3E9868"];
  "slot" -> "leaderElector" [label="slot overloads", color="#755BC6"];
  "slot" -> "groupElector" [label="audit id", color="#755BC6"];
  "events" -> "singleState" [label="state events", color="#2E8F89"];
  "localSingle" -> "leaderElector" [label="implements", color="#B9851B"];
  "localSingle" -> "suspendElector" [label="coroutines", color="#B9851B"];
  "localGroup" -> "groupElector" [label="implements", color="#B9851B"];
  "localGroup" -> "suspendGroup" [label="coroutines", color="#B9851B"];
}
