  n0 [label="Cron", fillcolor="#ffffff", color="#5B8DEF", width=3.19, height=1.00, pos="195.00,498.00!"];
  n1 [label="Node-1", fillcolor="#ffffff", color="#58A978", width=3.19, height=1.00, pos="527.50,498.00!"];
  n2 [label="Node-2", fillcolor="#ffffff", color="#D6A441", width=3.19, height=1.00, pos="860.00,498.00!"];
  n3 [label="Node-3", fillcolor="#ffffff", color="#DC6B82", width=3.19, height=1.00, pos="1192.50,498.00!"];
  n4 [label="Redis", fillcolor="#ffffff", color="#45A7A1", width=3.19, height=1.00, pos="1525.00,498.00!"];
  n0 -> n1 [];
