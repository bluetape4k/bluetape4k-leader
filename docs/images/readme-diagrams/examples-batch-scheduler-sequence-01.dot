  n4 -> n2 [style=dashed];
  n4 -> n3 [style=dashed];
  r10p1 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="591.50,-826.00!"];
  r10p2 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="591.50,-860.00!"];
  n1 -> r10p1 [arrowhead=none];
  r10p1 -> r10p2 [arrowhead=none];
  r10p2 -> n1 [];
  n1 -> n4 [];
}
