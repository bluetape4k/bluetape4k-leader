digraph "leader-zookeeper-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runAsyncIfLeader(lockName)\\n+ state(lockName): LeaderState"];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\ncoroutine context handle"];
  "groupContract" [label="<<core group interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName): T?\\n+ activeCount / availableSlots"];
  "suspendGroupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ state(lockName): LeaderGroupState"];
  "zkLeader" [label="<<blocking + async implementation>>\\nZooKeeperLeaderElector\\nCuratorFramework client\\nmutex recipe per lock path\\nacquire(waitTimeMs)\\nwatchdog disabled by design"];
  "zkSuspend" [label="<<coroutine implementation>>\\nZooKeeperSuspendLeaderElector\\nsingle-thread owner dispatcher\\nblocking acquire/release bridge\\nNonCancellable cleanup\\ncloses dispatcher after run"];
  "zkGroup" [label="<<semaphore group implementation>>\\nZooKeeperLeaderGroupElector\\nCurator semaphore recipe\\nacquire Lease within waitTime\\nparticipantNodes activeCount\\nlease.nodeName becomes slotId"];
  "zkSuspendGroup" [label="<<coroutine semaphore group>>\\nZooKeeperSuspend Group\\nZooKeeperSuspendLeaderGroupElector\\nDispatchers.IO acquire\\nNonCancellable lease.close\\nmarkReleased before close"];
  "factories" [label="<<factory + extensions>>\\nFactory Entrypoints\\nZooKeeperLeaderElectorFactory\\nZooKeeperLeaderGroupElectorFactory\\nZooKeeperSuspendLeaderElectorFactory\\nCuratorFramework runIfLeader* extensions"];
  "singleDelegates" [label="<<mutex liveness delegates>>\\nSingle Extend Delegates\\nZooKeeperLockExtendDelegate\\nZooKeeperSuspendLockExtendDelegate\\nisAcquiredInThisProcess check\\nreturns Extended(Instant.MAX)"];
  "slotDelegates" [label="<<lease state delegates>>\\nSlot Extend Delegates\\nZooKeeperSlotExtendDelegate\\nZooKeeperSuspendSlotExtendDelegate\\nAtomicBoolean released flag\\nmarkReleased -> NotHeld"];
  "mutex" [label="<<single lock primitive>>\\nCurator Mutex Recipe\\npath from ZooKeeperPaths\\nacquire(wait, MILLISECONDS)\\nrelease in finally block\\nephemeral recipe nodes"];
  "semaphore" [label="<<group permit primitive>>\\nCurator Semaphore Recipe\\npath from ZooKeeperPaths\\nmaxLeaders permits\\nLease nodeName used as slotId\\nLease.close releases permit"];
  "ownerThread" [label="<<Curator thread ownership>>\\nCall-Scoped Owner Thread\\nnew single-thread dispatcher\\ndaemon zookeeper-suspend-leader-*\\nacquire/release same owner thread\\ndispatcher closed after cleanup"];
  "paths" [label="<<base path builder>>\\nZooKeeperPaths\\ndefault /leader-election\\ndefault /leader-group-election\\ntrims trailing slash\\nroot base becomes /{lockName}"];
  "runtime" [label="<<session-backed coordination>>\\nZooKeeper Runtime Semantics\\nZooKeeper session owns liveness\\nsession expiry removes recipe nodes\\nleaseTime is not ZooKeeper TTL\\nautoExtend warning but disabled"];
  "classifier" [label="<<extender error policy>>\\nZooKeeperBackendErrorClassifier\\nConnectionLoss -> transient\\nOperationTimeout -> transient\\nSessionExpired -> non-transient\\nSessionMoved -> non-transient"];
  "zkLeader" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "zkSuspend" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "zkGroup" -> "groupContract" [label="inherit", color="#4F83BF"];
  "zkSuspendGroup" -> "suspendGroupContract" [label="inherit", color="#4F83BF"];
  "factories" -> "zkLeader" [label="dependency", color="#758297"];
  "factories" -> "zkSuspend" [label="dependency", color="#758297"];
  "factories" -> "zkGroup" [label="dependency", color="#758297"];
  "factories" -> "zkSuspendGroup" [label="dependency", color="#758297"];
  "zkLeader" -> "singleDelegates" [label="handle delegate", color="#B9851B"];
  "zkSuspend" -> "singleDelegates" [label="suspend delegate", color="#B9851B"];
  "zkGroup" -> "slotDelegates" [label="lease delegate", color="#755BC6"];
  "zkSuspendGroup" -> "slotDelegates" [label="suspend lease", color="#755BC6"];
  "singleDelegates" -> "mutex" [label="liveness check", color="#B9851B"];
  "slotDelegates" -> "semaphore" [label="slot", color="#755BC6"];
  "zkLeader" -> "mutex" [label="local", color="#B9851B"];
  "zkGroup" -> "semaphore" [label="slot", color="#755BC6"];
  "zkSuspendGroup" -> "semaphore" [label="slot", color="#755BC6"];
  "zkSuspend" -> "ownerThread" [label="owner thread", color="#758297"];
  "ownerThread" -> "mutex" [label="same-thread release", color="#758297"];
  "paths" -> "mutex" [label="single path", color="#758297"];
  "semaphore" -> "runtime" [label="recipe nodes", color="#758297"];
  "mutex" -> "runtime" [label="session nodes", color="#758297"];
  "paths" -> "runtime" [label="uses", color="#758297"];
  "ownerThread" -> "runtime" [label="dependency", color="#758297"];
  "classifier" -> "singleDelegates" [label="event", color="#2E8F89"];
  "classifier" -> "slotDelegates" [label="event", color="#2E8F89"];
}
