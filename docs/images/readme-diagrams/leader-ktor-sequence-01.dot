digraph "leader-ktor-sequence-01" {
  graph [layout=neato, rankdir=TB, splines=ortho, overlap=false, outputorder=edgesfirst, nodesep=0.55, ranksep=0.75, bgcolor="transparent", label="leader ktor Sequence Flow", labelloc=t];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, margin="0.16,0.10"];
  edge [color="#758297", penwidth=1.8, arrowsize=0.8, fontname="Comic Mono", fontsize=10];
  n0 [label="Application (Ktor)", fillcolor="#ffffff", color="#5B8DEF", width=4.17, height=1.00, pos="230.00,498.00!"];
  n1 [label="Leader Election", fillcolor="#ffffff", color="#58A978", width=4.17, height=1.00, pos="678.00,498.00!"];
  n2 [label="leaderScheduled", fillcolor="#ffffff", color="#D6A441", width=4.17, height=1.00, pos="1126.00,498.00!"];
  n3 [label="Suspend Leader", fillcolor="#ffffff", color="#DC6B82", width=4.17, height=1.00, pos="1574.00,498.00!"];
  n0 -> n1 [];
  n1 -> n0 [style=dashed];
  n0 -> n2 [];
  n2 -> n0 [style=dashed];
  n2 -> n3 [];
  n3 -> n2 [style=dashed];
  r7p1 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="1190.00,-292.00!"];
  r7p2 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="1190.00,-326.00!"];
  n2 -> r7p1 [arrowhead=none];
  r7p1 -> r7p2 [arrowhead=none];
  r7p2 -> n2 [];
  n0 -> n1 [];
