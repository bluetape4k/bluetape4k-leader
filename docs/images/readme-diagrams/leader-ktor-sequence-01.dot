digraph "leader-ktor-sequence-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "app" [label="Ktor Application Module"];
  "plugin" [label="Leader Election Plugin"];
  "job" [label="Scheduled Job"];
  "elector" [label="Suspend Leader Elector"];
  "registry" [label="Management Registry"];
  "route" [label="Management Route"];
  "app" -> "plugin" [label="install plugin with required leaderElection", color="#4F83BF"];
  "plugin" -> "plugin" [label="validate config and store in Application attributes", color="#2E8F89"];
  "plugin" -> "route" [label="install GET management route when enabled", color="#4F83BF"];
  "app" -> "job" [label="leaderScheduled(lockName, period, action)", color="#4F83BF"];
  "job" -> "registry" [label="register lockName for management visibility", color="#718A35"];
  "job" -> "elector" [label="runIfLeader(lockName) each active cycle", color="#B9851B"];
  "elector" -> "job" [label="execute suspend action with lock handle context", color="#3E9868"];
  "job" -> "job" [label="delay(period), then continue next cycle", color="#4F63C7"];
  "job" -> "job" [label="log WARN and keep next cycle alive", color="#4F63C7"];
  "app" -> "route" [label="GET /management/leaderElection", color="#4F83BF"];
  "route" -> "registry" [label="snapshot known lock names", color="#2E8F89"];
  "route" -> "elector" [label="state(lockName) for each registered lock", color="#4F83BF"];
  "elector" -> "route" [label="LeaderState status, audit id, lease expiry", color="#3E9868"];
  "route" -> "app" [label="respondText JSON without content negotiation", color="#3E9868"];
}
