digraph "readme-table-relationships-erd-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "modules" [label="Module table"];
  "backends" [label="Backend capability table"];
  "examples" [label="Example table"];
  "benchmarks" [label="Benchmark table"];
  "assets" [label="Diagram and chart assets"];
  "modules" -> "backends" [label="dependency"];
  "backends" -> "examples" [label="call"];
  "modules" -> "benchmarks" [label="metric"];
  "benchmarks" -> "assets" [label="metric"];
  "examples" -> "assets" [label="success"];
  "backends" -> "assets" [label="dependency"];
}
