digraph "bluetape4k-leader-sequence-03" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "caller" [label="Caller"];
  "group" [label="SuspendLeaderGroupElector"];
  "slot" [label="Slot namespace"];
  "backend" [label="Backend primitive"];
  "body" [label="Group leader body"];
  "caller" -> "group" [label="runIfLeader(groupName, slots, body)", color="#4F83BF"];
  "group" -> "slot" [label="build slot candidates groupName#0..N", color="#2E8F89"];
  "group" -> "backend" [label="tryAcquire first available slot token", color="#B9851B"];
  "backend" -> "group" [label="slot token acquired", color="#3E9868"];
  "group" -> "body" [label="execute body with slot ownership", color="#4F83BF"];
  "body" -> "group" [label="result for owned slot", color="#3E9868"];
  "group" -> "backend" [label="release owned slot token", color="#755BC6"];
  "group" -> "caller" [label="return leader result and slot metadata", color="#3E9868"];
  "backend" -> "group" [label="no available slot before waitTime", color="#C94D68"];
  "group" -> "caller" [label="return null/skipped group result", color="#C94D68"];
}
