digraph "leader-mongodb-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runAsyncIfLeader(lockName)\\n+ state(lockName): LeaderState"];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\ncoroutine context handle"];
  "groupContract" [label="<<core group interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName): T?\\n+ activeCount / availableSlots"];
  "suspendGroupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ state(lockName): LeaderGroupState"];
  "mongoLeader" [label="<<blocking + async implementation>>\\nMongoLeaderElector\\nsync MongoCollection<Document>\\ncreates MongoLock\\nautoExtend watchdog optional\\nhistory recorder optional"];
  "mongoSuspend" [label="<<coroutine implementation>>\\nMongoSuspendLeaderElector\\nCoroutineMongoCollection<Document>\\ncreates MongoSuspendLock\\nwithContext(handle element)\\nNonCancellable unlock"];
  "mongoGroup" [label="<<slot group implementation>>\\nMongoLeaderGroupElector\\nsync group collection\\nrandomized slot iteration\\nslotKey lockName:slot:N\\ngroup watchdog disabled"];
  "mongoSuspendGroup" [label="<<coroutine slot group>>\\nMongoSuspend Group\\nMongoSuspendLeaderGroupElector\\nsync collection for state queries\\ncoroutine collection for locks\\nsame namespace required"];
  "factories" [label="<<factory + module options>>\\nFactory And Options\\nMongoLeaderElectorFactory\\nMongoLeaderGroupElectorFactory\\nMongoLeaderElectionOptions.retryDelay\\nMongoLeaderGroupElectionOptions.maxLeaders"];
  "singleDelegates" [label="<<renewal delegates>>\\nSingle Extend Delegates\\nMongoLockExtendDelegate\\nMongoSuspendLockExtendDelegate\\nshare lock with LeaderLockHandle\\nclassify Mongo backend errors"];
  "slotDelegates" [label="<<group renewal delegates>>\\nSlot Extend Delegates\\nMongoSlotExtendDelegate\\nMongoSuspendSlotExtendDelegate\\nextend lockName:slot:N\\nmanual LockExtender path"];
  "mongoLock" [label="<<findOneAndUpdate lock>>\\nMongoLock\\ntoken: Base58 fencing value\\nexpired filter + upsert AFTER\\nE11000 means contended\\ndelete or minLease update"];
  "mongoSuspendLock" [label="<<coroutine Mongo lock>>\\nMongoSuspendLock\\ncoroutine driver retry loop\\nensureActive while acquiring\\ntoken check before unlock\\nsame extendDetailed contract"];
  "mongoCollections" [label="<<TTL document store>>\\nMongo Lock Collections\\nbluetape4k_leader_locks\\nbluetape4k_leader_group_locks\\nfields: _id, token, expireAt\\nTTL index expireAfterSeconds=0"];
  "history" [label="<<optional audit store>>\\nMongo History Sink\\nMongoLeaderHistorySink\\ncollection bluetape4k_leader_history\\nrecords ACQUIRED/COMPLETED/FAILED\\nindexer adds TTL retention index"];
  "classifier" [label="<<watchdog error policy>>\\nMongoBackendErrorClassifier\\ntimeout / socket -> transient\\nnot primary / recovering -> transient\\nauth / write concern -> non-transient\\nfeeds CompositeBackendErrorClassifier"];
  "dualCollections" [label="<<namespace invariant>>\\nSuspend Group Dual Collections\\nsync MongoCollection: activeCount/state\\nCoroutineMongoCollection: acquire/release\\ncollection namespace must match\\nTTL monitor can lag up to 60 seconds"];
  "mongoLeader" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "mongoSuspend" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "mongoGroup" -> "groupContract" [label="inherit", color="#4F83BF"];
  "mongoSuspendGroup" -> "suspendGroupContract" [label="inherit", color="#4F83BF"];
  "factories" -> "mongoLeader" [label="dependency", color="#758297"];
  "factories" -> "mongoSuspend" [label="dependency", color="#758297"];
  "factories" -> "mongoGroup" [label="dependency", color="#758297"];
  "factories" -> "mongoSuspendGroup" [label="dependency", color="#758297"];
  "mongoLeader" -> "singleDelegates" [label="handle delegate", color="#B9851B"];
  "mongoSuspend" -> "singleDelegates" [label="suspend delegate", color="#B9851B"];
  "mongoGroup" -> "slotDelegates" [label="slot delegate", color="#755BC6"];
  "mongoSuspendGroup" -> "slotDelegates" [label="suspend slot", color="#755BC6"];
  "singleDelegates" -> "mongoLock" [label="sync extend", color="#B9851B"];
  "singleDelegates" -> "mongoSuspendLock" [label="local", color="#B9851B"];
  "slotDelegates" -> "mongoLock" [label="slot", color="#755BC6"];
  "slotDelegates" -> "mongoSuspendLock" [label="suspend slot", color="#755BC6"];
  "mongoLock" -> "mongoCollections" [label="findOneAndUpdate", color="#758297"];
  "mongoSuspendLock" -> "mongoCollections" [label="coroutine driver", color="#758297"];
  "mongoSuspendGroup" -> "dualCollections" [label="dependency", color="#758297"];
  "dualCollections" -> "mongoCollections" [label="uses", color="#758297"];
  "mongoLeader" -> "history" [label="event", color="#2E8F89"];
  "mongoGroup" -> "history" [label="event", color="#2E8F89"];
  "classifier" -> "singleDelegates" [label="event", color="#2E8F89"];
  "classifier" -> "slotDelegates" [label="event", color="#2E8F89"];
}
