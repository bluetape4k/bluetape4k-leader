digraph "leader-redis-lettuce-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runAsyncIfLeader(lockName)\\n+ state(lockName): LeaderState"];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\ncoroutine context handle"];
  "groupContract" [label="<<core group interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName): T?\\n+ activeCount / availableSlots"];
  "suspendGroupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ state(lockName): LeaderGroupState"];
  "lettuceLeader" [label="<<blocking + async implementation>>\\nLettuceLeaderElector\\nStatefulRedisConnection<String,String>\\ncreates LettuceLock\\nautoExtend watchdog optional\\noptional history recorder"];
  "lettuceSuspend" [label="<<coroutine implementation>>\\nLettuceSuspendLeaderElector\\nuses Lettuce async commands\\ncreates LettuceSuspendLock\\nwithContext(handle element)\\nNonCancellable unlock"];
  "lettuceGroup" [label="<<slot-token group implementation>>\\nLettuceLeaderGroupElector\\nreuses slotGroups map\\ncreates LettuceSlotTokenGroup\\ntoken becomes slotId\\ngroup watchdog disabled"];
  "lettuceSuspendGroup" [label="<<coroutine slot group>>\\nLettuceSuspend Group\\nLettuceSuspendLeaderGroupElector\\nuses same SlotTokenGroup primitive\\ntryAcquireSuspending\\nNonCancellable slot release"];
  "factories" [label="<<factory + extensions>>\\nFactory Entrypoints\\nLettuceLeaderElectorFactory\\nLettuceLeaderGroupElectorFactory\\nLettuceSuspendLeaderElectorFactory\\nStatefulRedisConnection extensions"];
  "singleDelegates" [label="<<renewal delegates>>\\nSingle Extend Delegates\\nLettuceLockExtendDelegate\\nLettuceSuspendLockExtendDelegate\\nshare lock with LeaderLockHandle\\nR2 watchdog skip deadline"];
  "slotDelegates" [label="<<group renewal delegates>>\\nSlot Extend Delegates\\nLettuceSlotExtendDelegate\\nLettuceSuspendSlotExtendDelegate\\nextend slot token via server TIME\\nmanual LockExtender path"];
  "lettuceLock" [label="<<Redis SET NX PX lock>>\\nLettuceLock\\ntoken: Base58 fencing value\\nSET key token NX PX lease\\nLua token unlock / PEXPIRE\\nasync retry uses same token"];
  "slotGroup" [label="<<ZSET slot-token primitive>>\\nLettuceSlotTokenGroup\\nslotKey: lg:{lockName}\\nmember token, score expiryAtMs\\nmetaKey stores LeaderSlot leaderId\\nno legacy semaphore dependency"];
  "lettuceSuspendLock" [label="<<coroutine Redis lock>>\\nLettuceSuspendLock\\nasyncCommands.set NX PX\\ndelay retry + ensureActive\\nLua token unlock / PEXPIRE\\nsuspend native extendDetailed"];
  "scriptRunner" [label="<<Lua execution helper>>\\nRedisScriptRunner\\nRedisScript.sha1\\nEVALSHA first\\nNOSCRIPT falls back to EVAL\\nsync / async / suspend entrypoints"];
  "redisKeys" [label="<<Redis storage contract>>\\nRedis Runtime Keys\\nsingle lock key: SET NX PX\\ngroup ZSET: lg:{lockName}\\ngroup hash: lg:{lockName}:meta\\nACQUIRE evicts expired scores"];
  "classifier" [label="<<watchdog error policy>>\\nLettuceBackendErrorClassifier\\nRedisCommandTimeout -> transient\\nRedisConnection -> transient\\nRedisCommandExecution -> non-transient\\nother errors delegated"];
  "lettuceLeader" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "lettuceSuspend" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "lettuceGroup" -> "groupContract" [label="inherit", color="#4F83BF"];
  "lettuceSuspendGroup" -> "suspendGroupContract" [label="inherit", color="#4F83BF"];
  "factories" -> "lettuceLeader" [label="dependency", color="#758297"];
  "factories" -> "lettuceSuspend" [label="dependency", color="#758297"];
  "factories" -> "lettuceGroup" [label="dependency", color="#758297"];
  "factories" -> "lettuceSuspendGroup" [label="dependency", color="#758297"];
  "lettuceLeader" -> "singleDelegates" [label="handle delegate", color="#B9851B"];
  "lettuceSuspend" -> "singleDelegates" [label="suspend delegate", color="#B9851B"];
  "lettuceGroup" -> "slotDelegates" [label="slot delegate", color="#755BC6"];
  "lettuceSuspendGroup" -> "slotDelegates" [label="suspend slot", color="#755BC6"];
  "singleDelegates" -> "lettuceLock" [label="sync extend", color="#B9851B"];
  "singleDelegates" -> "lettuceSuspendLock" [label="local", color="#B9851B"];
  "slotDelegates" -> "slotGroup" [label="slot", color="#755BC6"];
  "lettuceGroup" -> "slotGroup" [label="slot", color="#755BC6"];
  "lettuceSuspendGroup" -> "slotGroup" [label="slot", color="#755BC6"];
  "lettuceLock" -> "scriptRunner" [label="unlock / extend", color="#758297"];
  "lettuceSuspendLock" -> "scriptRunner" [label="suspend Lua", color="#758297"];
  "slotGroup" -> "scriptRunner" [label="acquire release status", color="#758297"];
  "scriptRunner" -> "redisKeys" [label="EVALSHA / EVAL", color="#758297"];
  "lettuceLock" -> "redisKeys" [label="dependency", color="#758297"];
  "slotGroup" -> "redisKeys" [label="ZSET + meta hash", color="#755BC6"];
  "classifier" -> "singleDelegates" [label="event", color="#2E8F89"];
  "classifier" -> "slotDelegates" [label="event", color="#2E8F89"];
}
