digraph "leader-core-sequence-02" {
  graph [layout=neato, rankdir=TB, splines=ortho, overlap=false, outputorder=edgesfirst, nodesep=0.55, ranksep=0.75, bgcolor="transparent", label="Single-leader: lock acquire/release", labelloc=t];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, margin="0.16,0.10"];
  edge [color="#758297", penwidth=1.8, arrowsize=0.8, fontname="Comic Mono", fontsize=10];
  n0 [label="Caller", fillcolor="#ffffff", color="#5B8DEF", width=3.19, height=1.00, pos="195.00,498.00!"];
  n1 [label="LeaderElector", fillcolor="#ffffff", color="#58A978", width=3.19, height=1.00, pos="594.00,498.00!"];
  n2 [label="LockStore", fillcolor="#ffffff", color="#D6A441", width=3.19, height=1.00, pos="993.00,498.00!"];
  n0 -> n1 [];
  n1 -> n2 [];
  n2 -> n1 [style=dashed];
  n1 -> n0 [];
  n0 -> n1 [style=dashed];
  n1 -> n2 [];
  n1 -> n0 [style=dashed];
  n2 -> n1 [style=dashed];
  n1 -> n0 [style=dashed];
