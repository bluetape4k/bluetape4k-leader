digraph "leader-redis-lettuce-sequence-02" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "caller" [label="Caller"];
  "elector" [label="Lettuce Redis elector"];
  "backend" [label="Redis key"];
  "body" [label="Leader body"];
  "cleanup" [label="Recovery path"];
  "caller" -> "elector" [label="runIfLeader(lockName, options, body)", color="#4F83BF"];
  "elector" -> "backend" [label="SET lockKey token NX PX leaseTime", color="#B9851B"];
  "backend" -> "elector" [label="token accepted", color="#3E9868"];
  "elector" -> "body" [label="execute protected leader body", color="#4F83BF"];
  "body" -> "elector" [label="body result", color="#3E9868"];
  "elector" -> "backend" [label="Lua compare token then DEL", color="#755BC6"];
  "elector" -> "caller" [label="return body result", color="#3E9868"];
  "backend" -> "elector" [label="existing owner token blocks acquire", color="#C94D68"];
  "elector" -> "cleanup" [label="Redis TTL deletes unreleased crash token", color="#2E8F89"];
  "elector" -> "caller" [label="return skipped result", color="#C94D68"];
}
