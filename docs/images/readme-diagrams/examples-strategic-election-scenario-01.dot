digraph "examples-strategic-election-scenario-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "tick" [label="Candidate Scan"];
  "nodeA" [label="Candidate A"];
  "nodeB" [label="Candidate B"];
  "nodeC" [label="Candidate C"];
  "backend" [label="local leader slot"];
  "recovery" [label="Score Refresh"];
  "skipped" [label="Peers Skip"];
  "leader" [label="One Leader Runs"];
  "tick" -> "nodeA" [label="call"];
  "tick" -> "nodeB" [label="call"];
  "tick" -> "nodeC" [label="call"];
  "nodeA" -> "backend" [label="contention"];
  "nodeB" -> "backend" [label="contention"];
  "nodeC" -> "backend" [label="contention"];
  "backend" -> "leader" [label="success"];
  "backend" -> "skipped" [label="skip"];
  "backend" -> "recovery" [label="release"];
}
