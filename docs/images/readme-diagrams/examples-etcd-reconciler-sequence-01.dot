digraph "examples-etcd-reconciler-sequence-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "trigger" [label="Reconcile Tick"];
  "coord" [label="ClusterReconciler"];
  "elector" [label="EtcdLeaderElector"];
  "backend" [label="etcd lease key"];
  "work" [label="Apply Desired State"];
  "peer" [label="Skipped Peer"];
  "trigger" -> "coord" [label="start reconcile tick", color="#4F83BF"];
  "coord" -> "elector" [label="runIfLeader with source options", color="#4F83BF"];
  "elector" -> "backend" [label="attempt backend ownership", color="#B9851B"];
  "backend" -> "elector" [label="owner token accepted", color="#3E9868"];
  "elector" -> "work" [label="execute apply desired state", color="#3E9868"];
  "work" -> "elector" [label="return leader result", color="#3E9868"];
  "elector" -> "backend" [label="release or renew for lease revoke handoff", color="#755BC6"];
  "backend" -> "elector" [label="lock already owned", color="#C94D68"];
  "elector" -> "peer" [label="return skipped result", color="#C94D68"];
  "peer" -> "trigger" [label="cycle completes without duplicate work", color="#C94D68"];
}
