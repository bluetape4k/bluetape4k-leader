digraph "examples-k8s-lease-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "trigger" [label="Lease Attempt"];
  "nodeA" [label="Candidate Node A"];
  "nodeB" [label="Candidate Node B"];
  "coordinator" [label="K8sLeaseExample"];
  "backend" [label="Lease resource"];
  "elector" [label="KubernetesLeaseLeaderElector"];
  "recovery" [label="RenewTime Takeover"];
  "work" [label="Holder Operation"];
  "trigger" -> "nodeA" [label="call"];
  "trigger" -> "nodeB" [label="call"];
  "nodeA" -> "coordinator" [label="call"];
  "nodeB" -> "coordinator" [label="call"];
  "coordinator" -> "elector" [label="dependency"];
  "elector" -> "backend" [label="contention"];
  "coordinator" -> "work" [label="success"];
  "backend" -> "recovery" [label="release"];
}
