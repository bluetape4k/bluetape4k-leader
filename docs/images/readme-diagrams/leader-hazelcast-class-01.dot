digraph "leader-hazelcast-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName): T?\\n+ runAsyncIfLeader(lockName)\\n+ state(lockName): LeaderState"];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\ncoroutine context handle"];
  "groupContract" [label="<<core group interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName): T?\\n+ activeCount / availableSlots"];
  "suspendGroupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ state(lockName): LeaderGroupState"];
  "hazelcastLeader" [label="<<blocking + async implementation>>\\nHazelcastLeaderElector\\nuses bluetape4k:leader:locks\\ncreates HazelcastLock\\nautoExtend watchdog optional\\nasync release is thread-unbound"];
  "hazelcastSuspend" [label="<<coroutine implementation>>\\nHazelcastSuspendLeaderElector\\nuses same single lock map\\ncreates HazelcastSuspendLock\\nwithContext(handle element)\\nNonCancellable release"];
  "hazelcastGroup" [label="<<slot group implementation>>\\nHazelcastLeaderGroupElector\\nuses group lock map\\niterates lockName:slot:N\\nactiveCount reads slot keys\\ngroup watchdog disabled"];
  "hazelcastSuspendGroup" [label="<<coroutine slot group>>\\nHazelcastSuspend Group\\nHazelcastSuspendLeaderGroupElector\\nensureActive while trying slots\\ncreates suspend slot lock\\nNonCancellable slot release"];
  "factories" [label="<<factory + extensions>>\\nFactory Entrypoints\\nHazelcastLeaderElectorFactory\\nHazelcastLeaderGroupElectorFactory\\nHazelcastInstance.runIfLeader*\\nHazelcastInstance.suspendRunIfLeader*"];
  "singleDelegates" [label="<<renewal delegates>>\\nSingle Extend Delegates\\nHazelcastLockExtendDelegate\\nHazelcastSuspendLockExtendDelegate\\nshare lock with LeaderLockHandle\\nclassify backend errors"];
  "slotDelegates" [label="<<group renewal delegates>>\\nSlot Extend Delegates\\nHazelcastSlotExtendDelegate\\nHazelcastSuspendSlotExtendDelegate\\nextend lockName:slot:N\\nmanual LockExtender path"];
  "hazelcastLock" [label="<<IMap token lock>>\\nHazelcastLock\\ntoken: Base58 fencing value\\nputIfAbsent(key, token, TTL)\\nremove(key, token)\\nreplace + setTtl renewal"];
  "hazelcastSuspendLock" [label="<<suspend IMap token lock>>\\nHazelcastSuspendLock\\nblocking IMap wrapped in Dispatchers.IO\\ndelay retry loop\\ntoken check before unlock\\nsame extendDetailed contract"];
  "hazelcastMap" [label="<<runtime primitive>>\\nHazelcast IMap Store\\nsingle map: bluetape4k:leader:locks\\ngroup map: bluetape4k:leader:group:locks\\nno CP Subsystem required\\nnear-cache must stay disabled"];
  "hazelcastClassifier" [label="<<watchdog error policy>>\\nHazelcastBackendErrorClassifier\\nRetryable / TargetNotMember -> transient\\nWrongTarget -> transient\\nHazelcastException -> non-transient\\nfeeds CompositeBackendErrorClassifier"];
  "hazelcastLeader" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "hazelcastSuspend" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "hazelcastGroup" -> "groupContract" [label="inherit", color="#4F83BF"];
  "hazelcastSuspendGroup" -> "suspendGroupContract" [label="inherit", color="#4F83BF"];
  "factories" -> "hazelcastLeader" [label="factory create", color="#758297"];
  "factories" -> "hazelcastGroup" [label="group create", color="#758297"];
  "factories" -> "hazelcastSuspend" [label="extensions", color="#758297"];
  "factories" -> "hazelcastSuspendGroup" [label="suspend ext", color="#758297"];
  "hazelcastLeader" -> "singleDelegates" [label="handle delegate", color="#B9851B"];
  "hazelcastSuspend" -> "singleDelegates" [label="suspend delegate", color="#B9851B"];
  "hazelcastGroup" -> "slotDelegates" [label="slot delegate", color="#755BC6"];
  "hazelcastSuspendGroup" -> "slotDelegates" [label="suspend slot", color="#755BC6"];
  "singleDelegates" -> "hazelcastLock" [label="sync extend", color="#B9851B"];
  "singleDelegates" -> "hazelcastSuspendLock" [label="suspend extend", color="#B9851B"];
  "slotDelegates" -> "hazelcastLock" [label="slot lock", color="#755BC6"];
  "slotDelegates" -> "hazelcastSuspendLock" [label="suspend slot lock", color="#755BC6"];
  "hazelcastLock" -> "hazelcastMap" [label="putIfAbsent TTL", color="#758297"];
  "hazelcastSuspendLock" -> "hazelcastMap" [label="Dispatchers.IO", color="#758297"];
  "hazelcastClassifier" -> "singleDelegates" [label="event", color="#2E8F89"];
  "hazelcastClassifier" -> "slotDelegates" [label="event", color="#2E8F89"];
}
