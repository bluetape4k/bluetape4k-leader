digraph "examples-tenant-aggregator-flow-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "start" [label="Tenant Cycle"];
  "validate" [label="Validate Example Inputs"];
  "attempt" [label="R2DBC leader electors"];
  "decision" [label="Leadership Result"];
  "release" [label="Release Or Extend"];
  "execute" [label="Aggregate Tenant Metrics"];
  "executed" [label="Return Executed"];
  "skipped" [label="Return Skipped"];
  "start" -> "validate" [label="call"];
  "validate" -> "attempt" [label="dependency"];
  "attempt" -> "decision" [label="contention"];
  "decision" -> "execute" [label="success"];
  "execute" -> "release" [label="release"];
  "release" -> "executed" [label="success"];
  "decision" -> "skipped" [label="skip"];
}
