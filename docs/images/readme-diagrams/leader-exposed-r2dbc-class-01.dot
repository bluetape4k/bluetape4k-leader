digraph "leader-exposed-r2dbc-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "suspendContract" [label="<<core suspend interface>>\\nSuspendLeaderElector\\n+ suspend runIfLeader(lockName)\\n+ runIfLeaderResultSuspend(slot)\\n+ state(lockName): LeaderState"];
  "factoryContract" [label="<<core SPI interfaces>>\\nSuspend Factories\\nSuspendLeaderElectorFactory\\nSuspendLeaderGroupElectorFactory\\ncreate(options): suspend elector"];
  "groupContract" [label="<<core suspend group>>\\nSuspendLeaderGroupElector\\n+ maxLeaders: Int\\n+ suspend runIfLeader(lockName)\\n+ activeCount / availableSlots"];
  "r2dbcElector" [label="<<R2DBC implementation>>\\nR2DBC Suspend Elector\\nExposedR2DbcSuspendLeaderElector\\nimplements SuspendLeaderElector\\ncreates ExposedR2dbcLock\\nNonCancellable unlock path"];
  "factoryImpl" [label="<<factory + extensions>>\\nR2DBC Factory Entrypoints\\nExposedR2DbcSuspendLeaderElectorFactory\\nExposedR2DbcSuspendLeaderGroupElectorFactory\\nR2dbcDatabase.suspendRunIfLeader*\\ninvokes schema-safe electors"];
  "r2dbcGroupElector" [label="<<R2DBC group implementation>>\\nR2DBC Suspend Group\\nExposedR2DbcSuspendLeaderGroupElector\\nrandomized slot iteration\\nactiveCountSuspend DB query\\nrecordHistory gates audit writes"];
  "r2dbcLock" [label="<<single suspend lock>>\\nExposedR2dbcLock\\ntoken: Base58 fencing token\\nsuspendTransaction per attempt\\nUPDATE expired row\\ninsertIgnore then SELECT token"];
  "schemaInit" [label="<<coroutine schema bootstrap>>\\nExposedR2dbcSchemaInitializer\\nMutex + ConcurrentHashMap guard\\nSchemaUtils.createMissingTablesAndColumns\\nrequires H2 MODE for insertIgnore"];
  "r2dbcGroupLock" [label="<<slot suspend lock>>\\nExposedR2dbcGroupLock\\n(lockName, slot) composite owner\\nsuspendTransaction per slot\\ninsertIgnore slot row\\nSELECT token + slot ownership"];
  "lockTable" [label="<<Exposed table>>\\nLeaderLockTable\\nPK lockName\\nlockOwner\\ntoken\\nlockedAt / lockedUntil"];
  "historySink" [label="<<audit sink + inline group audit>>\\nExposed Suspend History\\nExposedSuspendLeaderHistorySink\\nSuspendSafeLeaderHistoryRecorder\\ngroup elector writes when recordHistory\\nbest-effort ACQUIRED/COMPLETED/FAILED"];
  "groupTable" [label="<<Exposed table>>\\nLeaderGroupLockTable\\nPK(lockName, slot)\\nlockOwner\\ntoken\\nlockedAt / lockedUntil"];
  "historyTable" [label="<<Exposed table>>\\nLeaderLockHistoryTable\\nid PK\\nlockName + token\\nstatus lifecycle\\nslot / slotId for group audit"];
  "r2dbcElector" -> "suspendContract" [label="inherit", color="#4F83BF"];
  "factoryImpl" -> "factoryContract" [label="inherit", color="#4F83BF"];
  "r2dbcGroupElector" -> "groupContract" [label="inherit", color="#4F83BF"];
  "factoryImpl" -> "r2dbcElector" [label="creates", color="#758297"];
  "factoryImpl" -> "r2dbcGroupElector" [label="creates", color="#758297"];
  "r2dbcElector" -> "r2dbcLock" [label="creates", color="#B9851B"];
  "r2dbcGroupElector" -> "r2dbcGroupLock" [label="per slot", color="#B9851B"];
  "r2dbcLock" -> "lockTable" [label="uses", color="#758297"];
  "r2dbcGroupLock" -> "groupTable" [label="uses", color="#758297"];
  "schemaInit" -> "lockTable" [label="dependency", color="#758297"];
  "schemaInit" -> "groupTable" [label="dependency", color="#758297"];
  "r2dbcElector" -> "historySink" [label="optional recorder", color="#2E8F89"];
  "r2dbcGroupElector" -> "historySink" [label="recordHistory", color="#2E8F89"];
  "historySink" -> "historyTable" [label="writes", color="#758297"];
}
