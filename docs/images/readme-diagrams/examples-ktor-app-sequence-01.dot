digraph "examples-ktor-app-sequence-01" {
  graph [layout=neato, rankdir=TB, splines=ortho, overlap=false, outputorder=edgesfirst, nodesep=0.55, ranksep=0.75, bgcolor="transparent", label="ktor app Sequence Flow", labelloc=t];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, margin="0.16,0.10"];
  edge [color="#758297", penwidth=1.8, arrowsize=0.8, fontname="Comic Mono", fontsize=10];
  n0 [label="Client", fillcolor="#ffffff", color="#5B8DEF", width=4.17, height=1.00, pos="230.00,498.00!"];
  n1 [label="Ktor Node-1", fillcolor="#ffffff", color="#58A978", width=4.17, height=1.00, pos="633.20,498.00!"];
  n2 [label="Ktor Node-2", fillcolor="#ffffff", color="#D6A441", width=4.17, height=1.00, pos="1036.40,498.00!"];
  n3 [label="Leader Election", fillcolor="#ffffff", color="#DC6B82", width=4.17, height=1.00, pos="1439.60,498.00!"];
  n4 [label="StatsAggregator", fillcolor="#ffffff", color="#45A7A1", width=4.17, height=1.00, pos="1842.80,498.00!"];
  n5 [label="Redis", fillcolor="#ffffff", color="#8A72D6", width=4.17, height=1.00, pos="2246.00,498.00!"];
  n1 -> n3 [];
  n2 -> n3 [];
  n1 -> n5 [];
  n2 -> n5 [];
  n5 -> n1 [style=dashed];
  n5 -> n2 [style=dashed];
  n1 -> n4 [];
  n0 -> n1 [];
  n1 -> n0 [style=dashed];
  n0 -> n2 [];
  n2 -> n0 [style=dashed];
}
