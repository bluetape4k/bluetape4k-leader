digraph "leader-micrometer-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "aopSource" [label="Spring AOP Callbacks"];
  "directSource" [label="Direct Elector Calls"];
  "listenerSource" [label="Listener Registry"];
  "historySource" [label="History Recorder"];
  "aopRecorder" [label="AOP Metrics Recorder"];
  "decorators" [label="Instrumented Decorators"];
  "listener" [label="Micrometer Listener"];
  "history" [label="Counter-Aware History Sink"];
  "registry" [label="Application MeterRegistry"];
  "aopMeters" [label="AOP Meter Family"];
  "directMeters" [label="Direct Meter Family"];
  "eventHistoryMeters" [label="Event And History Meters"];
  "export" [label="Export Backend"];
  "aopSource" -> "aopRecorder" [label="call"];
  "directSource" -> "decorators" [label="call"];
  "listenerSource" -> "listener" [label="call"];
  "historySource" -> "history" [label="call"];
  "aopRecorder" -> "registry" [label="dependency"];
  "decorators" -> "registry" [label="dependency"];
  "listener" -> "registry" [label="dependency"];
  "history" -> "registry" [label="dependency"];
  "registry" -> "aopMeters" [label="metric"];
  "aopMeters" -> "directMeters" [label="metric"];
  "directMeters" -> "eventHistoryMeters" [label="metric"];
  "aopMeters" -> "export" [label="success"];
  "eventHistoryMeters" -> "export" [label="success"];
}
