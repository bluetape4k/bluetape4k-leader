digraph "leader-consul-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "caller" [label="Application Caller"];
  "endpoint" [label="ConsulEndpoint"];
  "options" [label="Consul Options"];
  "single" [label="Single Leader Electors"];
  "group" [label="Group Leader Electors"];
  "client" [label="ConsulLockClient"];
  "lease" [label="Lease Handle And Extender"];
  "session" [label="Consul Session"];
  "singleKey" [label="Single KV Key"];
  "groupKeys" [label="Group Slot KV Keys"];
  "agentApi" [label="Consul HTTP API"];
  "caller" -> "single" [label="call"];
  "caller" -> "group" [label="call"];
  "endpoint" -> "client" [label="dependency"];
  "single" -> "client" [label="call"];
  "group" -> "client" [label="call"];
  "single" -> "lease" [label="success"];
  "group" -> "lease" [label="success"];
  "lease" -> "client" [label="retry"];
  "client" -> "session" [label="dependency"];
  "client" -> "singleKey" [label="contention"];
  "client" -> "groupKeys" [label="contention"];
  "client" -> "agentApi" [label="dependency"];
  "session" -> "singleKey" [label="release"];
}
