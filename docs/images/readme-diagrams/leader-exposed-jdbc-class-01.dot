digraph "leader-exposed-jdbc-class-01" {
  graph [rankdir=BT, bgcolor="transparent", splines=ortho, nodesep=0.75, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.8];
  "leaderContract" [label="<<core interface>>\\nLeaderElector\\n+ runIfLeader(lockName)\\n+ runAsyncIfLeader(lockName)"];
  "virtualContract" [label="<<core interface>>\\nVirtualThreadLeaderElector\\n+ runAsyncIfLeader(lockName)\\nVirtualFuture<T?> result"];
  "groupContract" [label="<<core interface>>\\nLeaderGroupElector\\n+ maxLeaders: Int\\n+ runIfLeader(lockName)\\n+ state(lockName)"];
  "jdbcElector" [label="<<JDBC implementation>>\\nExposedJdbcLeaderElector\\nimplements LeaderElector\\ncreates ExposedJdbcLock\\nstarts lease auto-extender\\nrecords optional history"];
  "virtualElector" [label="<<adapter implementation>>\\nExposedJdbc VirtualThread\\nExposedJdbcVirtualThreadLeaderElector\\ndelegate: ExposedJdbcLeaderElector\\nwraps delegate in virtualFuture"];
  "jdbcGroupElector" [label="<<JDBC group implementation>>\\nExposedJdbcLeaderGroupElector\\nimplements LeaderGroupElector\\nrandomized slot iteration\\ncreates ExposedJdbcGroupLock\\nstate uses LeaderGroupLockTable"];
  "jdbcLock" [label="<<single lock delegate>>\\nExposedJdbcLock\\ntoken: Base58 fencing token\\nUPDATE expired row\\nINSERT new row on missing lock\\nSELECT token ownership"];
  "jdbcGroupLock" [label="<<slot lock delegate>>\\nExposedJdbcGroupLock\\n(lockName, slot) composite owner\\nUPDATE expired slot\\nINSERT slot row\\nSELECT token + slot ownership"];
  "schemaInit" [label="<<schema bootstrap>>\\nExposedJdbcSchemaInitializer\\nensureSchema(db)\\nSchemaUtils.createMissingTablesAndColumns\\nruns once per Database URL"];
  "historySink" [label="<<audit sink>>\\nExposedLeaderHistorySink\\nrecord ACQUIRED\\nrecord COMPLETED / FAILED\\ncleanup old rows"];
  "lockTable" [label="<<Exposed table>>\\nLeaderLockTable\\nPK lockName\\nlockOwner\\ntoken\\nlockedAt / lockedUntil"];
  "historyTable" [label="<<Exposed table>>\\nLeaderLockHistoryTable\\nid PK\\nlockName + token\\nstatus lifecycle\\nslotId for group audit"];
  "groupTable" [label="<<Exposed table>>\\nLeaderGroupLockTable\\nPK(lockName, slot)\\nlockOwner\\ntoken\\nlockedAt / lockedUntil"];
  "jdbcElector" -> "leaderContract" [label="inherit", color="#4F83BF"];
  "virtualElector" -> "virtualContract" [label="inherit", color="#4F83BF"];
  "jdbcGroupElector" -> "groupContract" [label="inherit", color="#4F83BF"];
  "virtualElector" -> "jdbcElector" [label="dependency", color="#758297"];
  "jdbcElector" -> "jdbcLock" [label="creates", color="#B9851B"];
  "jdbcGroupElector" -> "jdbcGroupLock" [label="per slot", color="#B9851B"];
  "jdbcLock" -> "lockTable" [label="UPDATE INSERT SELECT", color="#758297"];
  "jdbcGroupLock" -> "groupTable" [label="slot rows", color="#758297"];
  "schemaInit" -> "lockTable" [label="creates", color="#758297"];
  "schemaInit" -> "groupTable" [label="creates", color="#758297"];
  "jdbcElector" -> "historySink" [label="optional history", color="#2E8F89"];
  "jdbcGroupElector" -> "historySink" [label="group audit", color="#2E8F89"];
  "historySink" -> "historyTable" [label="writes", color="#758297"];
}
