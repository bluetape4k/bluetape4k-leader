  r9p1 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="294.00,-602.00!"];
  r9p2 [label="", shape=point, width=0.03, height=0.03, fixedsize=true, style=invis, pos="294.00,-636.00!"];
  n0 -> r9p1 [arrowhead=none];
  r9p1 -> r9p2 [arrowhead=none];
