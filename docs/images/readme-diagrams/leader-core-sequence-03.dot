digraph "leader-core-sequence-03" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "caller" [label="Caller"];
  "group" [label="Core group elector"];
  "slots" [label="Slot namespace"];
  "backend" [label="Slot primitive"];
  "body" [label="Group body"];
  "caller" -> "group" [label="runIfLeader(groupName, maxLeaders, body)", color="#4F83BF"];
  "group" -> "slots" [label="build slot keys 0..maxLeaders-1", color="#2E8F89"];
  "group" -> "backend" [label="tryAcquire first free slot token", color="#B9851B"];
  "backend" -> "group" [label="slot token accepted", color="#3E9868"];
  "group" -> "body" [label="execute body for owned slot", color="#4F83BF"];
  "body" -> "group" [label="slot result", color="#3E9868"];
  "group" -> "backend" [label="release owned slot token", color="#755BC6"];
  "group" -> "caller" [label="return group result and slot", color="#3E9868"];
  "backend" -> "group" [label="no slot accepted before waitTime", color="#C94D68"];
  "group" -> "caller" [label="return skipped group result", color="#C94D68"];
}
