digraph "bluetape4k-leader-sequence-02" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.7, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [fontname="Comic Mono", fontsize=10, arrowsize=0.7];
  "caller" [label="Caller"];
  "elector" [label="SuspendLeaderElector"];
  "backend" [label="Backend primitive"];
  "listener" [label="Listeners/metrics"];
  "body" [label="Leader body"];
  "caller" -> "elector" [label="runIfLeader(lockName, options, body)", color="#4F83BF"];
  "elector" -> "backend" [label="tryAcquire owner token within waitTime", color="#B9851B"];
  "backend" -> "elector" [label="ownership token acquired", color="#3E9868"];
  "elector" -> "listener" [label="notify acquired", color="#718A35"];
  "elector" -> "body" [label="execute leader-only body", color="#4F83BF"];
  "body" -> "elector" [label="body result or exception", color="#3E9868"];
  "elector" -> "backend" [label="release token or let lease expire on failure", color="#755BC6"];
  "elector" -> "caller" [label="return body result", color="#3E9868"];
  "backend" -> "elector" [label="contention or valid owner", color="#C94D68"];
  "elector" -> "listener" [label="notify skipped", color="#718A35"];
  "elector" -> "caller" [label="return null or skipped result", color="#C94D68"];
}
