digraph "leader-k8s-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "caller" [label="Application Caller"];
  "fabric8" [label="Caller-Owned Fabric8 Client"];
  "options" [label="Kubernetes Lease Options"];
  "rbac" [label="Namespace And RBAC"];
  "single" [label="Single Lease Electors"];
  "group" [label="Group Lease Electors"];
  "lock" [label="KubernetesLeaseLock"];
  "handle" [label="Lease Handle And Extender"];
  "singleLease" [label="Single Lease Object"];
  "slotLeases" [label="Group Slot Leases"];
  "version" [label="ResourceVersion Conflict"];
  "metadata" [label="Audit Annotations"];
  "caller" -> "single" [label="call"];
  "caller" -> "group" [label="call"];
  "fabric8" -> "lock" [label="dependency"];
  "options" -> "lock" [label="dependency"];
  "rbac" -> "metadata" [label="dependency"];
  "single" -> "lock" [label="call"];
  "group" -> "lock" [label="call"];
  "single" -> "handle" [label="success"];
  "group" -> "handle" [label="success"];
  "handle" -> "lock" [label="retry"];
  "lock" -> "version" [label="contention"];
  "singleLease" -> "version" [label="success"];
  "slotLeases" -> "version" [label="success"];
  "version" -> "metadata" [label="release"];
}
