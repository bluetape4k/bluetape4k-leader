digraph "leader-dynamodb-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "caller" [label="Application Caller"];
  "clients" [label="AWS SDK Clients"];
  "options" [label="DynamoDB Options"];
  "tableOwner" [label="Caller-Provisioned Table"];
  "single" [label="Single Leader Electors"];
  "group" [label="Group Slot Electors"];
  "client" [label="DynamoDbLockClient"];
  "extender" [label="Lease Handle And Extender"];
  "singleKey" [label="Single Lock Row"];
  "groupRows" [label="Group Slot Rows"];
  "logicalLease" [label="Logical Lease Fields"];
  "ttlCleanup" [label="DynamoDB TTL Cleanup"];
  "caller" -> "single" [label="call"];
  "caller" -> "group" [label="call"];
  "clients" -> "client" [label="dependency"];
  "options" -> "client" [label="dependency"];
  "tableOwner" -> "ttlCleanup" [label="dependency"];
  "single" -> "client" [label="call"];
  "group" -> "client" [label="call"];
  "single" -> "extender" [label="success"];
  "group" -> "extender" [label="success"];
  "extender" -> "client" [label="retry"];
  "client" -> "logicalLease" [label="dependency"];
  "logicalLease" -> "ttlCleanup" [label="release"];
  "singleKey" -> "logicalLease" [label="success"];
  "groupRows" -> "logicalLease" [label="success"];
}
