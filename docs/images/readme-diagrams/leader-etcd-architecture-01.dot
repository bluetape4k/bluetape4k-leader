digraph "leader-etcd-architecture-01" {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.65, ranksep=0.9];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#94A3B8", fontname="Comic Mono"];
  edge [color="#758297", fontname="Comic Mono", fontsize=10];
  "caller" [label="Application Caller"];
  "jetcd" [label="Caller-Owned jetcd Client"];
  "options" [label="Etcd Options"];
  "publisher" [label="Event Publisher"];
  "single" [label="Single Leader Electors"];
  "group" [label="Group Slot Electors"];
  "client" [label="EtcdLockClient"];
  "handle" [label="Lease Handle And Extender"];
  "lease" [label="Etcd Lease"];
  "singleKey" [label="Single Lock Key"];
  "groupKeys" [label="Group Slot Lock Keys"];
  "watch" [label="Ownership Key Watch"];
  "caller" -> "single" [label="call"];
  "caller" -> "group" [label="call"];
  "jetcd" -> "client" [label="dependency"];
  "options" -> "client" [label="dependency"];
  "publisher" -> "watch" [label="dependency"];
  "single" -> "client" [label="call"];
  "group" -> "client" [label="call"];
  "single" -> "handle" [label="success"];
  "group" -> "handle" [label="success"];
  "handle" -> "client" [label="retry"];
  "client" -> "lease" [label="dependency"];
  "lease" -> "singleKey" [label="success"];
  "singleKey" -> "groupKeys" [label="contention"];
  "groupKeys" -> "watch" [label="release"];
}
