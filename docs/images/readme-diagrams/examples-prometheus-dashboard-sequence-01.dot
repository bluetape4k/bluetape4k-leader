digraph "examples-prometheus-dashboard-sequence-01" {
  graph [layout=neato, rankdir=TB, splines=ortho, overlap=false, outputorder=edgesfirst, nodesep=0.55, ranksep=0.75, bgcolor="transparent", label="Prometheus Dashboard Sequence Flow", labelloc=t];
  node [shape=box, style="rounded,filled", fontname="Architects Daughter", fontsize=18, margin="0.16,0.10"];
  edge [color="#758297", penwidth=1.8, arrowsize=0.8, fontname="Comic Mono", fontsize=10];
  n0 [label="Scheduler", fillcolor="#ffffff", color="#5B8DEF", width=2.92, height=1.00, pos="215.00,498.00!"];
  n1 [label="Job bean", fillcolor="#ffffff", color="#58A978", width=2.92, height=1.00, pos="437.00,498.00!"];
  n2 [label="Redis lock", fillcolor="#ffffff", color="#D6A441", width=2.92, height=1.00, pos="659.00,498.00!"];
  n3 [label="Micrometer", fillcolor="#ffffff", color="#DC6B82", width=2.92, height=1.00, pos="881.00,498.00!"];
  n4 [label="Prometheus", fillcolor="#ffffff", color="#45A7A1", width=2.92, height=1.00, pos="1103.00,498.00!"];
  n5 [label="Grafana", fillcolor="#ffffff", color="#8A72D6", width=2.92, height=1.00, pos="1325.00,498.00!"];
  n0 -> n1 [];
  n1 -> n2 [];
  n2 -> n1 [style=dashed];
  n1 -> n3 [];
  n4 -> n1 [];
  n1 -> n4 [style=dashed];
  n5 -> n4 [];
  n4 -> n5 [style=dashed];
}
